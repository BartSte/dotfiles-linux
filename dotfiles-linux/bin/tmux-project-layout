#!/usr/bin/env bash
set -euo pipefail

session="${1:-${name:-}}"
directory="${2:-${directory:-}}"

if [[ -z "$session" || -z "$directory" ]]; then
    printf 'tmux-project-layout: missing session name or directory\n' >&2
    exit 1
fi

if [[ ! -d "$directory" ]]; then
    printf 'tmux-project-layout: directory not found: %s\n' "$directory" >&2
    exit 1
fi

if ! tmux has-session -t "$session" 2>/dev/null; then
    printf 'tmux-project-layout: tmux session not found: %s\n' "$session" >&2
    exit 1
fi

window_exists() {
    local window_name="$1"
    tmux list-windows -t "$session" -F '#{window_name}' | grep -Fxq "$window_name"
}

desired_window_exists() {
    local window_name
    for window_name in nvim shell codex; do
        if window_exists "$window_name"; then
            return 0
        fi
    done
    return 1
}

create_shell_window() {
    local window_name="$1"
    local window_id

    window_id=$(
        tmux new-window \
            -d \
            -P \
            -F '#{window_id}' \
            -t "$session:" \
            -n "$window_name" \
            -c "$directory"
    )
    tmux set-window-option -q -t "$window_id" automatic-rename off
    printf '%s\n' "$window_id"
}

send_command() {
    local target="$1"
    local command="$2"

    tmux send-keys -t "$target" "$command" C-m
}

create_or_adopt_nvim_window() {
    local window_count
    local window_id

    if window_exists nvim; then
        return 0
    fi

    window_count=$(tmux list-windows -t "$session" -F '#{window_id}' | wc -l)

    if [[ "$window_count" -eq 1 ]] && ! desired_window_exists; then
        window_id=$(tmux list-windows -t "$session" -F '#{window_id}')
        tmux rename-window -t "$window_id" nvim
        tmux set-window-option -q -t "$window_id" automatic-rename off
    else
        window_id=$(create_shell_window nvim)
    fi

    send_command "$window_id" nvim
}

create_or_adopt_nvim_window

if ! window_exists shell; then
    create_shell_window shell >/dev/null
fi

if ! window_exists codex; then
    codex_window_id=$(create_shell_window codex)
    send_command "$codex_window_id" codex
fi
