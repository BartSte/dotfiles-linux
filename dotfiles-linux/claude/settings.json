{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "permissions": {
        "allow": [
            "Bash(uv run pyright *)",
            "Bash(uv run ruff check *)",
            "Bash(uv run pytest *)",
            "Bash(git status)",
            "Bash(git diff -- *)"
        ],
        "deny": [
            "Read(./.env)",
            "Read(./.env.*)"
        ]
    },
    "model": "sonnet",
    "defaultMode": "acceptEdits",
    "sandbox": {
        "enabled": true
    },
    "enabledPlugins": {
        "pyright-lsp@claude-plugins-official": true
    }
}
