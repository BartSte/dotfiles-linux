#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SECRET_DOTFILES_DIR="${DOTFILES_SECRET_DIR:-$HOME/dotfiles-secret}"
SECRET_SOURCE_CONFIG="$SECRET_DOTFILES_DIR/codex/config.toml"
LEGACY_SOURCE_CONFIG="$SCRIPT_DIR/config.toml"
SOURCE_AGENTS="$SCRIPT_DIR/AGENTS.md"
SOURCE_SKILLS="$SCRIPT_DIR/skills"
OBSOLETE_PROFILES=(
  read_only.config.toml
  cheap.config.toml
  deep.config.toml
)
TARGET_DIR="$HOME/.codex"
TARGET_CONFIG="$TARGET_DIR/config.toml"
TARGET_AGENTS="$TARGET_DIR/AGENTS.md"
TARGET_SKILLS="$TARGET_DIR/skills"

if [[ -f "$SECRET_SOURCE_CONFIG" ]]; then
  SOURCE_CONFIG="$SECRET_SOURCE_CONFIG"
elif [[ -f "$LEGACY_SOURCE_CONFIG" ]]; then
  SOURCE_CONFIG="$LEGACY_SOURCE_CONFIG"
else
  if [[ "${CI:-}" == "true" || "${GITHUB_ACTIONS:-}" == "true" ]]; then
    echo "Missing Codex config in CI; skipping config symlink"
    SOURCE_CONFIG=""
  else
    echo "Missing Codex config. Expected one of:" >&2
    echo "  $SECRET_SOURCE_CONFIG" >&2
    echo "  $LEGACY_SOURCE_CONFIG" >&2
    exit 1
  fi
fi

mkdir -p "$TARGET_DIR"

if [[ -n "${SOURCE_CONFIG:-}" ]]; then
  if [[ -e "$TARGET_CONFIG" && ! -L "$TARGET_CONFIG" ]]; then
    rm -f "$TARGET_CONFIG"
  fi
  ln -sfn "$SOURCE_CONFIG" "$TARGET_CONFIG"
fi

for profile_name in "${OBSOLETE_PROFILES[@]}"; do
  target_profile="$TARGET_DIR/$profile_name"
  if [[ -L "$target_profile" ]]; then
    rm -f "$target_profile"
  fi
done

if [[ -e "$TARGET_AGENTS" && ! -L "$TARGET_AGENTS" ]]; then
  rm -f "$TARGET_AGENTS"
fi
ln -sfn "$SOURCE_AGENTS" "$TARGET_AGENTS"

if [[ -d "$SOURCE_SKILLS" ]]; then
  if [[ -L "$TARGET_SKILLS" ]]; then
    rm -f "$TARGET_SKILLS"
  fi
  mkdir -p "$TARGET_SKILLS"

  while IFS= read -r source_skill; do
    skill_name="$(basename "$source_skill")"
    target_skill="$TARGET_SKILLS/$skill_name"

    if [[ -e "$target_skill" && ! -L "$target_skill" ]]; then
      echo "Refusing to replace non-symlink Codex skill: $target_skill" >&2
      exit 1
    fi
    ln -sfn "$source_skill" "$target_skill"
  done < <(find "$SOURCE_SKILLS" -mindepth 1 -maxdepth 1 -type d ! -name '.*')
fi
